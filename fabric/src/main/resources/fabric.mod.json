{
  "schemaVersion": 1,
  "id": "sfcr",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contributors": [
    "${mod_credits}"
  ],
  "contact": {
    "homepage": "${mod_link}",
    "sources": "${mod_source}",
    "issues": "${mod_issue_tracker}"
  },
  "license": "${mod_license}",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.rimo.sfcr.SFCReFabric"
    ],
    "client": [
      "com.rimo.sfcr.SFCReFabric"
    ],
    "server": [
      "com.rimo.sfcr.SFCReFabric"
    ],
    "modmenu": [
      "com.rimo.sfcr.config.SFCReModMenuIntegration"
    ]
  },
  "mixins": [
    "sfcr.mixins.json",
    "sfcr.particlerain.mixins.json"
  ],
  "depends": {
    "fabric": "*",
    "minecraft": ">=${minecraft_version}",
    "architectury": ">=${architectury_version}"
  },
  "suggests": {
    "cloth-config2":">=${cloth_config_version}",
    "modmenu": ">=${modmenu_version}",
    "distanthorizons": ">=${distant_horizon_min_version}",
    "particlerain": "~${particle_rain_version}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.modrinth": "https://modrinth.com/mod/superfancyclouds-refabricated",
        "MCMOD.cn": "https://www.mcmod.cn/class/9053.html"
      }
    }
  }
}
