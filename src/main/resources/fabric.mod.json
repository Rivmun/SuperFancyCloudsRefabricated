{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contributors": [
    "${mod_contributor}"
  ],
  "contact": {
    "homepage": "${mod_homepage}",
    "sources": "${mod_sources}",
    "issues": "${mod_issues}"
  },
  "license": "${mod_license}",
  "icon": "${mod_icon}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "${mod_group}.${mod_id}.loaders.fabric.SFCReFabric"
    ],
    "client": [
      "${mod_group}.${mod_id}.loaders.fabric.SFCReFabric"
    ],
    "server": [
      "${mod_group}.${mod_id}.loaders.fabric.SFCReFabric"
    ],
    "modmenu": [
      "${mod_group}.${mod_id}.loaders.fabric.SFCReModMenuIntegration"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabric": "*",
    "minecraft": "${version_range}",
    "architectury": ">=${arch_api}"
  },
  "suggests": {
    "cloth-config2":">=${cloth}",
    "modmenu": "*",
    "distanthorizons": ">=${distanthorizons_min_version}",
    ${particlerain_deps}
    ${sereneseasons_deps}
    "seasons": ">=${fabricseasons_min_version}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.modrinth": "${mod_modrinth}",
        "MCMOD.cn": "${mod_mcmod}"
      }
    }
  }
}
